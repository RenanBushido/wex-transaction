# WEX Transaction API - Environment Configuration Example
# Copy this file to .env and update values for your environment

# Application Environment
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL Database Configuration
POSTGRES_USER=wexuser
POSTGRES_PASSWORD=wexpassword
POSTGRES_DB=wextransaction

# Database Port (for host connection)
DB_PORT=5432

# Application Port (for host connection)
APP_PORT=5000

# Database Connection String
# Format: Host=db;Port=5432;Database=<POSTGRES_DB>;Username=<POSTGRES_USER>;Password=<POSTGRES_PASSWORD>;
# The 'db' hostname resolves to PostgreSQL service within docker-compose network
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=wextransaction;Username=wexuser;Password=wexpassword;

# Rate Limiting Configuration
# POST endpoint limits (transaction creation)
RateLimiting__PostPolicy__PermitLimit=10
RateLimiting__PostPolicy__Window=00:01:00

# GET endpoint limits (transaction retrieval)
RateLimiting__GetPolicy__PermitLimit=30
RateLimiting__GetPolicy__Window=00:01:00

# Logging Configuration
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning

# External API Configuration (Treasury Exchange Rates)
ExchangeRateApi__BaseUrl=https://fiscaldata.treasury.gov
ExchangeRateApi__Timeout=30

# Development-specific settings (used when ASPNETCORE_ENVIRONMENT=Development)
# These override the main settings above when ASPNETCORE_ENVIRONMENT=Development
# Typically relaxed for easier local development and debugging
