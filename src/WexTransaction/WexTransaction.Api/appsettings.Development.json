{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=wextransaction;Username=wexuser;Password=wexpassword;",
    "WexTransactionConnection": "Host=db;Port=5432;Database=wextransaction;User Id=wexuser;Password=wexpassword"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "*" ],
    "AllowedMethods": [ "*" ],
    "AllowedHeaders": [ "*" ]
  },
  "RateLimiting": {
    "Policies": {
      "post-policy": {
        "PermitLimit": 100,
        "WindowSeconds": 60
      },
      "get-policy": {
        "PermitLimit": 300,
        "WindowSeconds": 60
      }
    }
  },
  "HealthCheck": {
    "Enabled": true
  }
}
