{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=wextransaction;Username=wexuser;Password=wexpassword;",
    "WexTransactionConnection": "Host=db;Port=5432;Database=wextransaction;User Id=wexuser;Password=wexpassword"
  },
  "TreasuryApi": {
    "BaseUrl": "https://api.fiscaldata.treasury.gov/services/api/fiscal_service",
    "TimeoutSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7000" ],
    "AllowedMethods": [ "GET", "POST" ],
    "AllowedHeaders": [ "Content-Type", "application/json" ]
  },
  "RateLimiting": {
    "Policies": {
      "post-policy": {
        "PermitLimit": 10,
        "WindowSeconds": 60
      },
      "get-policy": {
        "PermitLimit": 30,
        "WindowSeconds": 60
      }
    }
  },
  "HealthCheck": {
    "Enabled": true
  }
}
